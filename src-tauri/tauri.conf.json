{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Papr",
  "version": "0.4.5",
  "identifier": "com.thomas.papr",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Papr",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 560,
        "backgroundColor": "#F6F3EC",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 13, "y": 16 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["papr"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "News",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
